{
  "title": "Tally — pipeline health",
  "uid": "tally-main",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Ingest rate (events/sec)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(tally_events_accepted_total[1m])", "legendFormat": "accepted" },
        { "expr": "sum(rate(tally_events_rejected_total[1m])) by (reason)", "legendFormat": "rejected: {{reason}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Storage rate (events/sec)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(tally_events_inserted_total[1m])", "legendFormat": "inserted" },
        { "expr": "rate(tally_events_duplicate_total[1m])", "legendFormat": "duplicates (deduped)" },
        { "expr": "rate(tally_events_dropped_total[1m])", "legendFormat": "DROPPED (must be 0)" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Queue depth",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [{ "expr": "tally_queue_depth", "legendFormat": "waiting events" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Ingest latency p99 (s)",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(tally_ingest_duration_seconds_bucket[1m]))", "legendFormat": "p99" },
        { "expr": "histogram_quantile(0.50, rate(tally_ingest_duration_seconds_bucket[1m]))", "legendFormat": "p50" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Batch flush duration p99 (s)",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(tally_flush_duration_seconds_bucket[1m]))", "legendFormat": "p99 flush" }
      ]
    }
  ]
}
